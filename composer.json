{
  "name": "mage-os/project-community-edition",
  "description": "Community-built eCommerce Platform for Growth",
  "type": "project",
  "license": [
    "OSL-3.0",
    "AFL-3.0"
  ],
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "laminas/laminas-dependency-plugin": true,
      "mage-os/*": true,
      "php-http/discovery": true
    },
    "preferred-install": "dist",
    "sort-packages": true
  },
  "require": {
    "graycore/magento2-cors": "^2.1",
    "mage-os/composer-dependency-version-audit-plugin": "2.2.1",
    "mage-os/composer-root-update-plugin": "2.2.1",
    "mage-os/module-bundle-sample-data": "2.2.1",
    "mage-os/module-catalog-rule-sample-data": "2.2.1",
    "mage-os/module-catalog-sample-data": "2.2.1",
    "mage-os/module-cms-sample-data": "2.2.1",
    "mage-os/module-configurable-sample-data": "2.2.1",
    "mage-os/module-customer-sample-data": "2.2.1",
    "mage-os/module-downloadable-sample-data": "2.2.1",
    "mage-os/module-grouped-product-sample-data": "2.2.1",
    "mage-os/module-msrp-sample-data": "2.2.1",
    "mage-os/module-offline-shipping-sample-data": "2.2.1",
    "mage-os/module-product-links-sample-data": "2.2.1",
    "mage-os/module-review-sample-data": "2.2.1",
    "mage-os/module-sales-rule-sample-data": "2.2.1",
    "mage-os/module-sales-sample-data": "2.2.1",
    "mage-os/module-swatches-sample-data": "2.2.1",
    "mage-os/module-tax-sample-data": "2.2.1",
    "mage-os/module-theme-sample-data": "2.2.1",
    "mage-os/module-widget-sample-data": "2.2.1",
    "mage-os/module-wishlist-sample-data": "2.2.1",
    "mage-os/product-community-edition": "2.2.1",
    "mage-os/sample-data-media": "2.2.1"
  },
  "require-dev": {
    "mage-os/magento-allure-phpunit": "2.2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^0.7 || ^1.0",
    "dg/bypass-finals": "^1.4",
    "friendsofphp/php-cs-fixer": "^3.22",
    "carlos-mg89/oauth": "^0.8.17",
    "mage-os/magento-coding-standard": "2.2.1",
    "mage-os/magento2-functional-testing-framework": "2.2.1",
    "pdepend/pdepend": "3.x-dev",
    "phpmd/phpmd": "3.x-dev",
    "phpstan/phpstan": "^1.9",
    "phpunit/phpunit": "^10.5",
    "symfony/finder": "^6.4"
  },
  "autoload": {
    "psr-4": {
      "Magento\\Framework\\": "lib/internal/Magento/Framework/",
      "Magento\\Setup\\": "setup/src/Magento/Setup/",
      "Magento\\": "app/code/Magento/"
    },
    "psr-0": {
      "": [
        "app/code/",
        "generated/code/"
      ]
    },
    "files": [
      "app/etc/NonComposerComponentRegistration.php"
    ],
    "exclude-from-classmap": [
      "**/dev/**",
      "**/update/**",
      "*/*/Test/**/*Test"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Magento\\Sniffs\\": "dev/tests/static/framework/Magento/Sniffs/",
      "Magento\\Tools\\": "dev/tools/Magento/Tools/",
      "Magento\\Tools\\Sanity\\": "dev/build/publication/sanity/Magento/Tools/Sanity/",
      "Magento\\TestFramework\\Inspection\\": "dev/tests/static/framework/Magento/TestFramework/Inspection/",
      "Magento\\TestFramework\\Utility\\": "dev/tests/static/framework/Magento/TestFramework/Utility/",
      "Magento\\PhpStan\\": "dev/tests/static/framework/Magento/PhpStan/"
    }
  },
  "prefer-stable": true,
  "minimum-stability": "stable",
  "version": "2.2.1",
  "extra": {
    "magento-force": "override"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.mage-os.org/"
    }
  ]
}
