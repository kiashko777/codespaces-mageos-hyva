<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Framework\GraphQl\Schema\Type\Entity\DefaultMapper">
        <arguments>
            <argument name="map" xsi:type="array">
                <item name="snowdog_menu_node" xsi:type="array">
                    <item name="cms_block" xsi:type="string">SnowdogMenuCmsBlockNode</item>
                </item>
            </argument>
        </arguments>
    </type>

    <type name="Snowdog\Menu\Model\GraphQl\Resolver\Node\Identity">
        <plugin name="develo_snowdog_menu_graphql_ext_node_identity_cms_block_tags"
                type="Develo\SnowdogMenuGraphQlExtension\Plugin\GraphQl\Node\IdentityPlugin"/>
    </type>

    <type name="Snowdog\Menu\Model\GraphQl\Resolver\Menu\Identity">
        <plugin name="develo_snowdog_menu_graphql_ext_menu_identity_cms_block_tags"
                type="Develo\SnowdogMenuGraphQlExtension\Plugin\GraphQl\Menu\IdentityPlugin"/>
    </type>
</config>
